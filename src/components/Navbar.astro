---
const links = [
    { label: 'Home', href: '/' },
    { label: 'Works', href: '/works' },
    { label: 'Contact', href: '/contact' },
];
---

<nav
    class="border-border relative z-50 flex w-full items-center justify-between border-b px-8 py-9"
    transition:persist
>
    <a href="/" class="text-3xl leading-0 font-bold tracking-tight uppercase"
        >kong.ly</a
    >
    <button
        id="menu-toggle"
        class="relative h-[18px] w-[18px] cursor-pointer"
        aria-label="Toggle menu"
    >
        <div
            id="icon-dots"
            class="duration-fast absolute inset-0 grid grid-cols-2 place-items-center gap-2 transition-opacity"
        >
            <div class="bg-foreground h-[5px] w-[5px]"></div>
            <div class="bg-foreground h-[5px] w-[5px]"></div>
            <div class="bg-foreground h-[5px] w-[5px]"></div>
            <div class="bg-foreground h-[5px] w-[5px]"></div>
        </div>
        <div
            id="icon-close"
            class="duration-fast absolute inset-0 flex items-center justify-center opacity-0 transition-opacity"
        >
            <div class="bg-foreground absolute h-[1.5px] w-[18px] rotate-45">
            </div>
            <div class="bg-foreground absolute h-[1.5px] w-[18px] -rotate-45">
            </div>
        </div>
    </button>
</nav>

<div
    id="menu-overlay"
    class="bg-background px-section-x duration-normal pointer-events-none fixed inset-0 z-40 flex flex-col justify-center opacity-0 transition-opacity"
    transition:persist
>
    <ul class="gap-section-gap flex flex-col">
        {
            links.map((link) => (
                <li>
                    <a
                        href={link.href}
                        class="text-display-sm md:text-display-md duration-fast text-muted hover:text-foreground leading-none font-semibold -tracking-[7.5%] uppercase transition-colors"
                    >
                        {link.label}
                    </a>
                </li>
            ))
        }
    </ul>
</div>

<script>
    function initNavbar() {
        const toggle = document.getElementById('menu-toggle')!;
        const overlay = document.getElementById('menu-overlay')!;
        let open = false;

        function closeMenu() {
            open = false;
            overlay.classList.add('opacity-0', 'pointer-events-none');
            document
                .getElementById('icon-dots')!
                .classList.remove('opacity-0');
            document
                .getElementById('icon-close')!
                .classList.add('opacity-0');
            document.body.classList.remove('overflow-hidden');
        }

        toggle.addEventListener('click', () => {
            open = !open;
            overlay.classList.toggle('opacity-0', !open);
            overlay.classList.toggle('pointer-events-none', !open);
            document
                .getElementById('icon-dots')!
                .classList.toggle('opacity-0', open);
            document
                .getElementById('icon-close')!
                .classList.toggle('opacity-0', !open);
            document.body.classList.toggle('overflow-hidden', open);
        });

        overlay.querySelectorAll('a').forEach((link) => {
            link.addEventListener('click', () => {
                closeMenu();
            });
        });

        document.addEventListener('astro:before-preparation', closeMenu);
    }

    initNavbar();
    document.addEventListener('astro:page-load', initNavbar);
</script>
