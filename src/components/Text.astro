---
type Variant = "display" | "title" | "heading" | "body-lg" | "body" | "body-xl" | "label" | "overline" | "link" | "normal";

interface Props {
    variant: Variant;
    as?: string;
    class?: string;
};

import { twMerge } from "tailwind-merge";

const { variant, as, class: className } = Astro.props as Props;

interface VariantData {
    tag: string;
    classes: string;
}

const variantConfig: Record<Variant, VariantData> = {
    display: {
        tag: "h1",
        classes: "font-semibold uppercase text-display-sm md:text-display-md lg:text-display-lg leading-none -tracking-[7.5%] break-all",
    },
    title: {
        tag: "h2",
        classes: "font-semibold text-display-sm lg:text-title leading-none -tracking-[5%]",
    },
    "body-xl": {
        tag: "h2",
        classes: "text-4xl lg:text-5xl leading-12 lg:leading-14 font-normal md:font-medium tracking-tight"
    },
    heading: {
        tag: "h2",
        classes: "text-2xl font-medium tracking-tight",
    },
    "body-lg": {
        tag: "span",
        classes: "text-3xl lg:text-4xl leading-8 lg:leading-12 font-normal md:font-medium tracking-tighter",
    },
    body: {
        tag: "p",
        classes: "text-2xl font-medium tracking-tighter",
    },
    label: {
        tag: "span",
        classes: "text-sm font-normal tracking-tight",
    },
    overline: {
        tag: "span",
        classes: "text-base font-light tracking-wide uppercase text-subtle",
    },
    link: {
        tag: "p",
        classes: "text-sm md:text-base -tracking-[0.04em]",
    },
    normal: {
        tag: "p",
        classes: "text-sm md:text-base",
    }
};

const config = variantConfig[variant];
const Tag = as || config.tag;
---

<Tag class={twMerge(config.classes, className)}>
    <slot />
</Tag>
