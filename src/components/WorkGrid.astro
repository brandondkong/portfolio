---
import { sanityClient } from 'sanity:client';
import type { Work } from '../../sanity/workType';
import WorkCard from './WorkCard.astro';

interface Props {
    includeAll?: boolean;
};

const { includeAll = false } = Astro.props;

const WORKS_QUERY = includeAll
  ? `*[_type == "project" && defined(slug.current)]|order(_createdAt desc){ _id, title, slug, coverImage }`
  : `*[_type == "project" && defined(slug.current)]|order(_createdAt desc)[0...3]{ _id, title, slug, coverImage }`;
const works = await sanityClient.fetch<Work[]>(WORKS_QUERY);
---

<div class="grid grid-cols-1 lg:grid-cols-2 gap-content-gap">
    {works.map((work) => (
      <WorkCard
        work={work}
      />
    ))}
  </div>