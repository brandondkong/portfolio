---
type Variant = "primary" | "inverted" | "ghost";

interface Props {
    variant?: Variant;
    class?: string;
    href?: string;
};

import { twMerge } from "tailwind-merge";

const { variant = "primary", href, class: className } = Astro.props;

const base = "py-4 px-8 text-base transition-colors duration-fast font-normal tracking-tight";

const variants: Record<Variant, string> = {
    primary: "bg-surface text-foreground hover:bg-foreground hover:text-background",
    inverted: "bg-foreground text-background hover:bg-surface hover:text-foreground",
    ghost: "bg-footer-surface text-footer-foreground hover:bg-footer-foreground hover:text-footer-background",
};

const Tag = href ? "a" : "button";
---

<Tag href={href} class={twMerge(base, variants[variant], className)}>
    <slot />
</Tag>