---
interface Props {
    name: string;
    placeholder?: string;
    type?: astroHTML.JSX.HTMLInputTypeAttribute;
    class?: string;
}

import { twMerge } from 'tailwind-merge';
import { formBase } from '../lib/styles';

const {
    name,
    placeholder,
    type = 'text',
    class: className,
    ...rest
} = Astro.props;
---

<input
    type={type}
    name={name}
    placeholder={placeholder}
    class={twMerge(formBase, className)}
    {...rest}
/>
