---
import Button from "./Button.astro";
import Text from "./Text.astro";

interface Props {
    class?: string;
    hideBorder?: boolean;
    title?: string;
    buttonText?: string;
};

const { class: className, hideBorder = false, title, buttonText, ...rest } = Astro.props;
---

<section
class:list={["px-6 sm:px-20", !hideBorder && "border-t border-border", className]}
{...rest}
>
    {title && (
        <div class="flex flex-row items-center justify-between">
            <Text variant="heading">{title}</Text>
            {buttonText && <Button>{buttonText}</Button>}
        </div>
    )}
    <slot />
</section>
