---
import Button from "./Button.astro";
import Text from "./Text.astro";

interface SocialMedia {
    label: string;
    href: string;
};

const socialMediaLinks: SocialMedia[] = [
    {
        label: "GitHub",
        href: "https://github.com/brandondkong"
    },
    {
        label: "LinkedIn",
        href: "https://linkedin.com/in/brandondkong"
    },
    {
        label: "X",
        href: "https://x.com/brandondkong"
    },
]

const year = new Date().getFullYear();
---

<footer
id="footer" class="sticky bottom-0 z-0 min-h-screen bg-footer-background text-footer-foreground overflow-hidden"
>
    <div class="flex flex-col justify-between min-h-screen pt-36 py-4 px-6 sm:py-16 sm:px-20">
        <div class="flex items-center justify-start sm:justify-end gap-6">
            {
                socialMediaLinks.map(socialMedia => (
                    <a href={socialMedia.href} target="_blank">
                        <Text variant="normal">{ socialMedia.label }</Text>
                    </a>
                ))
            }
        </div>

        <div class="flex flex-col gap-8 sm:gap-10">
            <Text variant="body-xl">
                Got an idea worth building?<br />Let&apos;s make it real.
            </Text>
            <div class="flex items-center gap-3">
                <div class="relative flex items-center justify-center w-3 h-3">
                    <div class="absolute w-full h-full rounded-full bg-white animate-ping-slow opacity-75" />
                    <div class="relative w-2 h-2 rounded-full bg-white" />
                </div>
                <Text variant="normal"> Available for work </Text>
            </div>
            <Button class="w-full sm:w-fit hover:bg-neutral-800">
                Get in Touch
            </Button>
        </div>

        <div class="flex flex-col gap-6">
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-6">
                <div>
                    <Text variant="normal">
                        +1 (847) 834-9772
                    </Text>
                    <Text variant="normal">
                        brandon@kong.ly
                    </Text>
                </div>

                <div class="text-right sm:text-left">
                    <Text variant="normal">
                        Made with ❤️
                    </Text>
                    <Text variant="normal">
                        Inspired by Peter Hodak
                    </Text>
                </div>

                <div class="hidden sm:block sm:text-right">
                    <Text variant="normal">
                        All rights reserved,
                    </Text>
                    <Text variant="normal">
                        Brandon Kong © { year }
                    </Text>
                </div>
            </div>

            <div class="sm:hidden border-t border-white/20 pt-4 text-center">
                <Text variant="normal">
                    All rights reserved, Brandon Kong © { year }
                </Text>
            </div>
    </div>
</footer>

<script>
  const footer = document.getElementById("footer");
  const inner = footer?.firstElementChild as HTMLElement | null;
  if (footer && inner) {
    const offset = 800;
    inner.style.transform = `translateY(${offset}px)`;

    function onScroll() {
      const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
      const progress = Math.max(0, Math.min(1, window.scrollY / maxScroll));
      inner!.style.transform = `translateY(${offset * (1 - progress)}px)`;
    }

    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>