---
interface Props {
    name: string;
    placeholder?: string;
    rows?: number;
    class?: string;
}

import { twMerge } from 'tailwind-merge';
import { formBase } from '../lib/styles';

const { name, placeholder, rows = 4, class: className, ...rest } = Astro.props;
---

<textarea
    name={name}
    placeholder={placeholder}
    rows={rows}
    class={twMerge(formBase, 'resize-y', className)}
    {...rest}></textarea>
