---
interface Props {
    name: string;
    placeholder?: string;
    rows?: number;
    class?: string;
};

import { twMerge } from "tailwind-merge";

const { name, placeholder, rows = 4, class: className, ...rest } = Astro.props;

const base = "py-4 px-8 text-base font-normal tracking-tight bg-surface text-foreground placeholder:text-muted border border-border transition-colors duration-fast focus:outline-none focus:border-foreground resize-y";
---

<textarea
    name={name}
    placeholder={placeholder}
    rows={rows}
    class={twMerge(base, className)}
    {...rest}
/>
