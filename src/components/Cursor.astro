<div id="cursor"></div>

<style is:global>
	body {
		cursor: none;
	}
	body * {
		cursor: inherit;
	}

	#cursor {
		position: fixed;
		top: 0;
		left: 0;
		width: 28px;
		height: 28px;
		border-radius: 50%;
		backdrop-filter: invert(1);
		pointer-events: none;
		z-index: 9999;
		transition: transform 0.2s ease;
	}

	#cursor.hovering {
		transform: scale(2.4);
	}
</style>

<script>
	const cursor = document.getElementById("cursor")!;
	const ease = 0.5;

	let mouseX = 0;
	let mouseY = 0;
	let cursorX = 0;
	let cursorY = 0;

	document.addEventListener("mousemove", (e) => {
		mouseX = e.clientX;
		mouseY = e.clientY;

		const target = e.target as HTMLElement;
		const isHovering = target.closest("a, button, [role='button'], .project-card");
		cursor.classList.toggle("hovering", !!isHovering);
	});

	function animate() {
		cursorX += (mouseX - cursorX) * ease;
		cursorY += (mouseY - cursorY) * ease;
		cursor.style.left = `${cursorX - 20}px`;
		cursor.style.top = `${cursorY - 20}px`;
		requestAnimationFrame(animate);
	}

	animate();
</script>
