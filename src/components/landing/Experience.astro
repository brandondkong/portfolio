---
import type { SanityDocument } from "@sanity/client";
import { sanityClient } from "sanity:client";

import { urlFor } from "../../lib/sanity";

import Section from "../Section.astro";
import Text from "../Text.astro";

interface Experience extends SanityDocument {
  company: {
    name: string;
    logo: { asset: { _ref: string; _type: string } } | null;
  };
  role: string;
  startDate: string;
  endDate: string | null;
  description: string | null;
  order: number;
}

const EXPERIENCE_QUERY = `*[_type == "experience"]|order(order asc){ _id, company->{ name, logo }, role, startDate, endDate, description, order }`;
const experiences = await sanityClient.fetch<Experience[]>(EXPERIENCE_QUERY);

function formatDate(dateStr: string): string {
  const date = new Date(dateStr + "T00:00:00");
  return date.toLocaleDateString("en-US", { month: "short", year: "numeric" });
}

function formatRange(start: string, end: string | null): string {
  return `${formatDate(start)} — ${end ? formatDate(end) : "Present"}`;
}
---

<Section title="Experience" class="pt-8 pb-20 flex flex-col gap-12">
  <div class="flex flex-col">
    {experiences.map((exp, i) => (
      <div class:list={["py-10 sm:py-14 flex flex-col gap-6", i !== experiences.length - 1 && "border-b border-border"]}>
        <div class="flex items-center gap-3">
          {exp.company.logo && (
            <img
              src={urlFor(exp.company.logo).width(80).height(80).url()}
              alt={exp.company.name}
              width={32}
              height={32}
              class="rounded"
            />
          )}
          <Text variant="label" class="text-muted uppercase tracking-wide">{formatRange(exp.startDate, exp.endDate)}</Text>
        </div>
        <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 lg:gap-12">
          <div class="flex flex-col gap-2">
            <h3 class="text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight italic">{exp.company.name}</h3>
            <Text variant="body" class="text-muted">{exp.role}</Text>
          </div>
          {exp.description && (
            <Text variant="body-lg" class="text-muted text-justify max-w-md lg:pb-1 lg:indent-20">{exp.description}</Text>
          )}
        </div>
      </div>
    ))}
  </div>
</Section>
