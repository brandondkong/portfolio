---
import Text from "../../Text.astro";
import Section from "../../Section.astro";
import type { Work } from "../../../../sanity/workType";

interface Props {
  work: Work;
}

const { work } = Astro.props;
---

{work.features && work.features.length > 0 && (
  <Section title="Features" class="pt-section-top flex flex-col gap-section-gap">
    <div class="flex flex-col gap-content-gap max-w-2xl ml-auto">
      {work.features.map((feature) => (
        <div class="flex flex-col gap-tight-gap">
          <Text variant="body-xl">{feature.title}</Text>
          <Text variant="body-sm">{feature.description}</Text>
        </div>
      ))}
    </div>
  </Section>
)}
