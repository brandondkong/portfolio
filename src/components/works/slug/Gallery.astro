---
import Section from "../../Section.astro";
import { urlFor } from "../../../lib/sanity";
import type { Work } from "../../../../sanity/workType";

interface Props {
  work: Work;
}

const { work } = Astro.props;
const count = work.gallery?.length ?? 0;
---

{work.gallery && count > 0 && (
  <Section title="Gallery" class="pt-section-top pb-section-bottom flex flex-col gap-section-gap">
    <div class:list={[
      "grid gap-content-gap",
      count === 1 && "grid-cols-1 max-w-2xl",
      count >= 2 && "grid-cols-1 md:grid-cols-2",
    ]}>
      {work.gallery.map((image) => (
        <img
          src={urlFor(image).width(1200).url()}
          alt=""
          width={1200}
          height={800}
          class="w-full border border-border"
        />
      ))}
    </div>
  </Section>
)}
