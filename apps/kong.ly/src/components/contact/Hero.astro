---
import Text from '../common/Text.astro';
import SocialLink from '../common/SocialLink.astro';
import Section from '../common/Section.astro';
import Input from '../common/Input.astro';
import Textbox from '../common/Textbox.astro';
import Button from '../common/Button.astro';
import Reveal from '../common/Reveal.astro';
import { LINKEDIN_LINK } from '../../lib/constants';
---

<Section
    hideBorder
    paddingTop="hero"
    paddingBottom="none"
    class="gap-hero-gap flex flex-col"
>
    <div
        class="gap-element-gap flex flex-col-reverse items-start justify-between md:flex-row"
    >
        <Text variant="display" reveal aria-label="Shoot a Request">
            Shoot a<br />Request
        </Text>
    </div>
    <Reveal
        class="gap-content-gap flex flex-col items-start justify-between lg:flex-row"
    >
        <div class="flex-1">
            <SocialLink
                text="brandondkong"
                icon="brands/linkedin"
                cursorText="LinkedIn"
                href={LINKEDIN_LINK}
            />
        </div>

        <form
            id="contact-form"
            class="gap-content-gap flex w-full flex-[1.5] flex-col"
        >
            <Input
                name="name"
                placeholder="Your Name"
                class="w-full"
                required
            />
            <Input
                type="email"
                name="email"
                placeholder="Your Email"
                class="w-full"
                required
            />
            <Textbox name="message" placeholder="Your Message here" required />
            <Button variant="solid">Submit</Button>
        </form>
    </Reveal>
</Section>

<div
    id="toast"
    class="pointer-events-none fixed bottom-6 left-1/2 z-50 -translate-x-1/2 translate-y-4 rounded-sm px-6 py-3 text-sm font-medium tracking-tight opacity-0 transition-all duration-300 ease-out"
    role="status"
    aria-live="polite"
>
</div>

<script is:inline>
    function initContactForm() {
        var form = document.getElementById('contact-form');
        var toast = document.getElementById('toast');
        if (!form || !toast) return;

        var timeout;
        function showToast(message, success) {
            clearTimeout(timeout);
            toast.textContent = message;
            toast.className = toast.className
                .replace(/bg-\S+/g, '')
                .replace(/text-\S+/g, '');
            toast.classList.add(
                success ? 'bg-foreground' : 'bg-red-600',
                success ? 'text-background' : 'text-white',
            );
            toast.style.opacity = '1';
            toast.style.transform = 'translateX(-50%) translateY(0)';
            timeout = setTimeout(function () {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(-50%) translateY(1rem)';
            }, 4000);
        }

        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            var data = new FormData(form);
            var btn = form.querySelector('button');
            btn.disabled = true;
            btn.textContent = 'Sending...';

            try {
                var res = await fetch('/api/contact', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        name: data.get('name'),
                        email: data.get('email'),
                        message: data.get('message'),
                    }),
                });

                if (res.ok) {
                    showToast('Message sent!', true);
                    form.reset();
                } else {
                    showToast('Failed to send. Please try again.', false);
                }
            } catch {
                showToast('Failed to send. Please try again.', false);
            }

            btn.disabled = false;
            btn.textContent = 'Submit';
        });
    }

    document.addEventListener('astro:page-load', initContactForm);
</script>
