---
import Section from '../../common/Section.astro';
import { urlFor } from '../../../lib/sanity';
import type { Work } from '@kong/sanity';
import Reveal from '../../common/Reveal.astro';
import { twMerge } from 'tailwind-merge';

interface Props {
    work: Work;
}

const { work } = Astro.props;
const count = work.gallery?.length ?? 0;

const gridClass = twMerge(
    'gap-content-gap grid',
    count === 1 && 'max-w-2xl grid-cols-1',
    count >= 2 && 'grid-cols-1 md:grid-cols-2',
);
---

{
    work.gallery && count > 0 && (
        <Section hideBorder class="gap-section-gap flex flex-col">
            <Reveal class={gridClass}>
                {work.gallery.map((image, index) => (
                    <img
                        src={urlFor(image).width(1200).height(800).url()}
                        srcset={`${urlFor(image).width(600).height(400).url()} 600w, ${urlFor(image).width(1200).height(800).url()} 1200w`}
                        sizes="(max-width: 768px) 100vw, 50vw"
                        alt={`${work.title} screenshot ${index + 1}`}
                        width={1200}
                        height={800}
                        loading="lazy"
                        class="border-border w-full border"
                    />
                ))}
            </Reveal>
        </Section>
    )
}
