---
import type { Post } from '@kong/sanity';
import { urlFor } from '../lib/sanity';
import Text from './Text.astro';

interface Props {
    post: Post;
}

const { post } = Astro.props;

const date = new Date(post.publishedAt).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
});
---

<a
    href={`/blog/${post.slug.current}`}
    class="border-border group flex flex-col overflow-hidden border"
>
    {
        post.coverImage && (
            <div class="aspect-2/1 w-full overflow-hidden">
                <img
                    src={urlFor(post.coverImage).width(800).height(400).url()}
                    srcset={`${urlFor(post.coverImage).width(400).height(200).url()} 400w, ${urlFor(post.coverImage).width(800).height(400).url()} 800w`}
                    sizes="(max-width: 768px) 100vw, 50vw"
                    alt={post.title}
                    width={800}
                    height={400}
                    loading="lazy"
                    class="h-full w-full object-cover transition-transform duration-(--duration-normal) group-hover:scale-110"
                />
            </div>
        )
    }
    <div class="gap-element-gap border-border flex flex-col border-t p-6">
        <Text variant="overline">{date}</Text>
        <Text variant="heading" as="h3">{post.title}</Text>
        {post.excerpt && <Text variant="body" class="text-muted">{post.excerpt}</Text>}
        {
            post.tags && post.tags.length > 0 && (
                <div class="gap-tight-gap flex flex-wrap">
                    {post.tags.map((tag) => (
                        <span class="bg-surface text-muted rounded-full px-3 py-1 text-sm">
                            {tag}
                        </span>
                    ))}
                </div>
            )
        }
    </div>
</a>
