---
import Button from './Button.astro';
import Text from './Text.astro';

interface SocialMedia {
    label: string;
    href: string;
}

const socialMediaLinks: SocialMedia[] = [
    {
        label: 'GitHub',
        href: 'https://github.com/brandondkong',
    },
    {
        label: 'LinkedIn',
        href: 'https://linkedin.com/in/brandondkong',
    },
    {
        label: 'X',
        href: 'https://x.com/brandondkong',
    },
];

const year = new Date().getFullYear();
---

<footer
    id="footer"
    class="bg-footer-background text-footer-foreground sticky bottom-0 z-0 min-h-dvh overflow-hidden"
>
    <div
        class="px-section-x sm:px-section-x-sm pt-footer-top pb-footer-bottom sm:pb-footer-bottom-sm flex min-h-dvh flex-col justify-between"
    >
        <div
            class="gap-content-gap flex items-center justify-start sm:justify-end"
        >
            {
                socialMediaLinks.map((socialMedia) => (
                    <a
                        href={socialMedia.href}
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <Text variant="link">{socialMedia.label}</Text>
                    </a>
                ))
            }
        </div>

        <div class="gap-content-gap flex flex-col">
            <Text
                variant="body-xl"
                class="from-footer-foreground to-footer-foreground/20 bg-linear-to-r bg-clip-text text-transparent"
            >
                Got an idea worth building?<br />Let&apos;s make it real.
            </Text>
            <div class="gap-content-gap flex flex-col-reverse sm:flex-row">
                <Button href="/contact" variant="ghost" class="w-full sm:w-fit">
                    Get in Touch
                </Button>
                <div class="flex items-center gap-3">
                    <div
                        class="relative flex h-3 w-3 items-center justify-center"
                        aria-hidden="true"
                    >
                        <div
                            class="animate-ping-slow bg-footer-foreground absolute h-full w-full rounded-full opacity-75"
                        >
                        </div>
                        <div
                            class="bg-footer-foreground relative h-2 w-2 rounded-full"
                        >
                        </div>
                    </div>
                    <Text variant="normal"> Available for work</Text>
                </div>
            </div>
        </div>

        <div class="gap-content-gap flex flex-col">
            <div class="gap-content-gap grid grid-cols-2 sm:grid-cols-3">
                <div>
                    <Text variant="normal"> +1 (847) 834-9772 </Text>
                    <Text variant="normal"> brandon@kong.ly </Text>
                </div>

                <div class="text-right sm:text-left">
                    <Text variant="normal"> Made with ❤️ </Text>
                    <Text variant="normal"> Inspired by Peter Hodak </Text>
                </div>

                <div class="hidden sm:block sm:text-right">
                    <Text variant="normal"> All rights reserved, </Text>
                    <Text variant="normal">
                        Brandon Kong © {year}
                    </Text>
                </div>
            </div>

            <div
                class="border-footer-foreground/20 border-t pt-4 text-center sm:hidden"
            >
                <Text variant="normal">
                    All rights reserved, Brandon Kong © {year}
                </Text>
            </div>
        </div>
    </div>
</footer>

<script>
    function initFooterParallax() {
        const footer = document.getElementById('footer');
        const inner = footer?.firstElementChild as HTMLElement | null;
        if (!footer || !inner) return;

        const offset = 300;
        inner.style.transform = `translateY(${offset}px)`;

        function onScroll() {
            const mainContent = document.getElementById('main');
            if (!mainContent) return;
            const mainBottom = mainContent.getBoundingClientRect().bottom;
            const viewportH = window.visualViewport?.height ?? window.innerHeight;
            const progress = Math.max(
                0,
                Math.min(1, 1 - mainBottom / viewportH),
            );
            inner!.style.transform = `translateY(${offset * (1 - progress)}px)`;
        }

        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
    }

    initFooterParallax();
    document.addEventListener('astro:page-load', initFooterParallax);
</script>
