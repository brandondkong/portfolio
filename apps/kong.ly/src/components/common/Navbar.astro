---
const links = [
    { label: 'About', href: '/about' },
    { label: 'Works', href: '/works' },
    { label: 'Blog', href: '/blog' },
    { label: 'Contact', href: '/contact' },
];
---

<nav
    aria-label="Main"
    class="bg-background border-border relative z-50 flex w-full items-center justify-between border-b px-8 py-9"
    transition:persist
>
    <a
        id="nav-logo"
        href="/"
        class="text-3xl leading-none font-bold tracking-tight uppercase"
        >kong.ly</a
    >
    <button
        id="menu-toggle"
        class="relative flex h-11 w-11 cursor-pointer items-center justify-center"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="menu-overlay"
    >
        <div
            id="icon-dots"
            class="duration-fast grid h-[18px] w-[18px] grid-cols-2 place-items-center gap-2 transition-opacity"
            aria-hidden="true"
        >
            <div class="bg-foreground h-[5px] w-[5px]"></div>
            <div class="bg-foreground h-[5px] w-[5px]"></div>
            <div class="bg-foreground h-[5px] w-[5px]"></div>
            <div class="bg-foreground h-[5px] w-[5px]"></div>
        </div>
        <div
            id="icon-close"
            class="duration-fast absolute flex h-[18px] w-[18px] items-center justify-center opacity-0 transition-opacity"
            aria-hidden="true"
        >
            <div class="bg-foreground absolute h-[1.5px] w-[18px] rotate-45">
            </div>
            <div class="bg-foreground absolute h-[1.5px] w-[18px] -rotate-45">
            </div>
        </div>
    </button>
</nav>

<div
    id="menu-overlay"
    role="dialog"
    aria-label="Navigation menu"
    aria-modal="true"
    inert
    class="bg-background px-section-x duration-normal pointer-events-none fixed inset-0 z-40 flex flex-col justify-center opacity-0 transition-opacity"
    transition:persist
>
    <ul class="gap-section-gap flex flex-col">
        {
            links.map((link) => (
                <li>
                    <a
                        href={link.href}
                        class="md:text-display-sm duration-fast text-muted hover:text-foreground text-4xl leading-none font-semibold -tracking-[7.5%] uppercase transition-colors sm:text-5xl"
                    >
                        {link.label}
                    </a>
                </li>
            ))
        }
    </ul>
</div>

<script>
    let navbarController: AbortController | null = null;

    function initNavbar() {
        navbarController?.abort();
        navbarController = new AbortController();
        const signal = navbarController.signal;

        const logo = document.getElementById('nav-logo')!;
        const toggle = document.getElementById('menu-toggle')!;
        const overlay = document.getElementById('menu-overlay')!;
        let open = false;

        function closeMenu() {
            open = false;
            toggle.setAttribute('aria-expanded', 'false');
            overlay.classList.add('opacity-0', 'pointer-events-none');
            overlay.inert = true;
            document.getElementById('icon-dots')!.classList.remove('opacity-0');
            document.getElementById('icon-close')!.classList.add('opacity-0');
            document.body.classList.remove('overflow-hidden');
            toggle.focus();
        }

        function openMenu() {
            open = true;
            toggle.setAttribute('aria-expanded', 'true');
            overlay.classList.remove('opacity-0', 'pointer-events-none');
            overlay.inert = false;
            document.getElementById('icon-dots')!.classList.add('opacity-0');
            document
                .getElementById('icon-close')!
                .classList.remove('opacity-0');
            document.body.classList.add('overflow-hidden');

            const firstLink = overlay.querySelector('a');
            if (firstLink) firstLink.focus();
        }

        toggle.addEventListener(
            'click',
            () => {
                if (open) closeMenu();
                else openMenu();
            },
            { signal },
        );

        document.addEventListener(
            'keydown',
            (e) => {
                if (e.key === 'Escape' && open) closeMenu();
            },
            { signal },
        );

        document.addEventListener(
            'keydown',
            (e) => {
                if (e.key !== 'Tab' || !open) return;
                const overlayFocusable =
                    overlay.querySelectorAll<HTMLElement>('a, button');
                if (!overlayFocusable.length) return;
                const first = logo;
                const last = overlayFocusable[overlayFocusable.length - 1];

                if (e.shiftKey && document.activeElement === first) {
                    e.preventDefault();
                    last.focus();
                } else if (!e.shiftKey && document.activeElement === last) {
                    e.preventDefault();
                    first.focus();
                }
            },
            { signal },
        );

        overlay.querySelectorAll('a').forEach((link) => {
            link.addEventListener(
                'click',
                () => {
                    closeMenu();
                },
                { signal },
            );
        });

        document.addEventListener('astro:before-preparation', closeMenu, {
            signal,
        });
    }

    initNavbar();
    document.addEventListener('astro:page-load', initNavbar);
</script>
