---
import { Image } from 'astro:assets';
import type { Post } from '@kong/sanity';
import { urlFor } from '../../lib/sanity';
import Text from './Text.astro';

interface Props {
    post: Post;
    headingLevel?: 'h2' | 'h3';
}

const { post, headingLevel = 'h3' } = Astro.props;

const date = new Date(post.publishedAt).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
});
---

<a
    href={`/blog/${post.slug.current}`}
    class="border-border group flex flex-col overflow-hidden border"
>
    <div class="gap-element-gap flex flex-col p-6">
        <Text variant="overline">{date}</Text>
        <Text variant="heading" as={headingLevel}>{post.title}</Text>
        {
            post.excerpt && (
                <Text variant="body" class="text-muted">
                    {post.excerpt}
                </Text>
            )
        }
        {
            post.tags && post.tags.length > 0 && (
                <div class="gap-tight-gap flex flex-wrap">
                    {post.tags.map((tag) => (
                        <span class="bg-surface text-muted rounded-full px-3 py-1 text-sm">
                            {tag}
                        </span>
                    ))}
                </div>
            )
        }
    </div>
</a>
