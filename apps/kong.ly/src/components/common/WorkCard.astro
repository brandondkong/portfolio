---
import { Image } from 'astro:assets';
import type { Work } from '@kong/sanity';
import { urlFor } from '../../lib/sanity';
import Text from './Text.astro';

interface Props {
    work: Work;
    headingLevel?: 'h2' | 'h3';
}

const { work, headingLevel = 'h3' } = Astro.props;
---

<a
    href={`/works/${work.slug.current}`}
    class="work-card border-border group relative aspect-square h-auto w-full overflow-hidden border"
>
    <Image
        src={urlFor(work.coverImage).width(800).height(800).url()}
        widths={[400, 800]}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt={work.title}
        width={800}
        height={800}
        loading="lazy"
        class="absolute top-0 left-0 h-full w-full object-cover transition-transform duration-(--duration-normal) group-hover:scale-110"
    />
    <div
        class="xl:from-overlay duration-normal absolute inset-x-0 bottom-0 flex h-1/3 items-end bg-linear-to-t from-black/50 to-transparent p-6 opacity-100 transition-opacity sm:p-14 xl:h-3/4 xl:opacity-0 xl:group-hover:opacity-100"
    >
        <Text variant="body-xl" as={headingLevel} class="text-background"
            >{work.title}</Text
        >
    </div>
</a>
