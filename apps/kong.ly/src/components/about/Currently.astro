---
import { sanityClient } from 'sanity:client';

import Reveal from '../common/Reveal.astro';
import Section from '../common/Section.astro';
import Text from '../common/Text.astro';

const settings = await sanityClient.fetch<{ currentlyText: string | null }>(
    `*[_type == "siteSettings"][0]{ currentlyText }`,
);
---

{
    settings?.currentlyText && (
        <Section title="Currently" class="gap-section-gap flex flex-col">
            <Reveal>
                <Text variant="body-lg" class="max-w-2xl text-justify">
                    {settings.currentlyText}
                </Text>
            </Reveal>
        </Section>
    )
}
