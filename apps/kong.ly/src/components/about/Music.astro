---
import { Image } from 'astro:assets';
import { sanityClient } from 'sanity:client';
import type { MusicPick } from '@kong/sanity';

import Reveal from '../common/Reveal.astro';
import Section from '../common/Section.astro';
import Text from '../common/Text.astro';
import { urlFor } from '../../lib/sanity';

const settings = await sanityClient.fetch<{
    topMusic: MusicPick[] | null;
}>(`*[_type == "siteSettings"][0]{ topMusic }`);

const picks = settings?.topMusic ?? [];
---

{
    picks.length > 0 && (
        <Section
            title="Music"
            buttonText="My Spotify"
            href="https://open.spotify.com/user/0wy58v4k1seh4grvacxy5qp0j"
            buttonExternal
            class="gap-section-gap flex flex-col"
        >
            <Reveal class="gap-content-gap grid grid-cols-1 sm:grid-cols-3">
                {picks.map((pick) => {
                    const isSong = Boolean(pick.artist);
                    const Tag = pick.url ? 'a' : 'div';
                    const attrs = pick.url
                        ? {
                              href: pick.url,
                              target: '_blank',
                              rel: 'noopener noreferrer',
                          }
                        : {};
                    return (
                        <Tag
                            {...attrs}
                            class="border-border group gap-element-gap flex flex-col overflow-hidden border"
                        >
                            <Image
                                src={urlFor(pick.coverImage)
                                    .width(800)
                                    .height(800)
                                    .url()}
                                widths={[400, 800]}
                                sizes="(max-width: 640px) 100vw, 33vw"
                                alt={
                                    isSong
                                        ? `${pick.title} by ${pick.artist}`
                                        : pick.title
                                }
                                width={800}
                                height={800}
                                loading="lazy"
                                class="aspect-square w-full object-cover transition-transform duration-(--duration-normal) group-hover:scale-105"
                            />
                            <div class="gap-tight-gap flex flex-col p-6">
                                <Text variant="overline">
                                    {isSong ? 'Song' : 'Artist'}
                                </Text>
                                <Text variant="heading" as="h3">
                                    {pick.title}
                                </Text>
                                {isSong && (
                                    <Text variant="body-sm" class="text-muted">
                                        {pick.artist}
                                    </Text>
                                )}
                            </div>
                        </Tag>
                    );
                })}
            </Reveal>
        </Section>
    )
}
