---
import type { SanityDocument } from '@sanity/client';
import { sanityClient } from 'sanity:client';

import { urlFor } from '../../lib/sanity';

import Section from '../Section.astro';
import Text from '../Text.astro';
import Reveal from '../Reveal.astro';

interface Experience extends SanityDocument {
    company: {
        name: string;
        logo: { asset: { _ref: string; _type: string } } | null;
    };
    role: string;
    startDate: string;
    endDate: string | null;
    description: string | null;
    order: number;
}

const EXPERIENCE_QUERY = `*[_type == "experience"]|order(order asc){ _id, company->{ name, logo }, role, startDate, endDate, description, order }`;
const experiences = await sanityClient.fetch<Experience[]>(EXPERIENCE_QUERY);

function formatDate(dateStr: string): string {
    const date = new Date(dateStr + 'T00:00:00');
    return date.toLocaleDateString('en-US', {
        month: 'short',
        year: 'numeric',
    });
}

function formatRange(start: string, end: string | null): string {
    return `${formatDate(start)} — ${end ? formatDate(end) : 'Present'}`;
}
---

<Section
    title="Experience"
    class="pt-section-top pb-section-bottom gap-section-gap flex flex-col"
>
    <Reveal class="flex flex-col">
        {
            experiences.map((exp, i) => (
                <div
                    class:list={[
                        'gap-content-gap flex flex-col py-10 sm:py-14',
                        i !== experiences.length - 1 &&
                            'border-border border-b',
                    ]}
                >
                    <div class="gap-tight-gap flex items-center">
                        {exp.company.logo && (
                            <img
                                src={urlFor(exp.company.logo)
                                    .width(64)
                                    .height(64)
                                    .url()}
                                alt={exp.company.name}
                                width={32}
                                height={32}
                                loading="lazy"
                                class="rounded"
                            />
                        )}
                        <Text variant="overline">
                            {formatRange(exp.startDate, exp.endDate)}
                        </Text>
                    </div>
                    <div class="gap-element-gap lg:gap-section-gap flex flex-col lg:flex-row lg:items-start lg:justify-between">
                        <div class="gap-tight-gap flex flex-col">
                            <Text
                                variant="body-xl"
                                as="h3"
                                class="font-semibold"
                            >
                                {exp.company.name}
                            </Text>
                            <Text variant="body" class="text-muted">
                                {exp.role}
                            </Text>
                        </div>
                        {exp.description && (
                            <Text
                                variant="body-lg"
                                class="text-muted max-w-md text-justify lg:pb-1 lg:indent-20"
                            >
                                {exp.description}
                            </Text>
                        )}
                    </div>
                </div>
            ))
        }
    </Reveal>
</Section>
