---
import { PortableText } from 'astro-portabletext';
import Section from '../../Section.astro';
import Reveal from '../../Reveal.astro';
import type { Post } from '@kong/sanity';

interface Props {
    post: Post;
}

const { post } = Astro.props;
---

<Section class="pt-section-top pb-section-bottom">
    <Reveal>
        <div class="prose mx-auto max-w-3xl">
            <PortableText value={post.body} />
        </div>
    </Reveal>
</Section>

<style is:global>
    .prose h2 {
        font-size: 1.75rem;
        font-weight: 600;
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        line-height: 1.3;
    }

    .prose h3 {
        font-size: 1.375rem;
        font-weight: 600;
        margin-top: 2rem;
        margin-bottom: 0.75rem;
        line-height: 1.4;
    }

    .prose p {
        margin-bottom: 1.25rem;
        line-height: 1.75;
        color: var(--color-muted);
    }

    .prose a {
        color: var(--color-foreground);
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .prose a:hover {
        color: var(--color-muted);
    }

    .prose ul,
    .prose ol {
        margin-bottom: 1.25rem;
        padding-left: 1.5rem;
        color: var(--color-muted);
    }

    .prose ul {
        list-style-type: disc;
    }

    .prose ol {
        list-style-type: decimal;
    }

    .prose li {
        margin-bottom: 0.5rem;
        line-height: 1.75;
    }

    .prose blockquote {
        border-left: 2px solid var(--color-border);
        padding-left: 1.25rem;
        margin-bottom: 1.25rem;
        color: var(--color-subtle);
        font-style: italic;
    }

    .prose code {
        background-color: var(--color-surface);
        padding: 0.15rem 0.4rem;
        border-radius: 0.25rem;
        font-size: 0.875rem;
    }

    .prose pre {
        background-color: var(--color-surface);
        padding: 1.25rem;
        border-radius: 0.5rem;
        overflow-x: auto;
        margin-bottom: 1.25rem;
    }

    .prose pre code {
        background: none;
        padding: 0;
    }

    .prose img {
        width: 100%;
        margin-top: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .prose hr {
        border-color: var(--color-border);
        margin-top: 2.5rem;
        margin-bottom: 2.5rem;
    }
</style>
