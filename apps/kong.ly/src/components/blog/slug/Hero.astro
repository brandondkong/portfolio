---
import { Image } from 'astro:assets';
import Text from '../../common/Text.astro';
import Section from '../../common/Section.astro';
import Reveal from '../../common/Reveal.astro';
import { urlFor } from '../../../lib/sanity';
import type { Post } from '@kong/sanity';

interface Props {
    post: Post;
}

const { post } = Astro.props;

const date = new Date(post.publishedAt).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
});
---

<Section
    hideBorder
    paddingTop="hero"
    class="gap-section-gap mx-auto flex max-w-5xl flex-col items-center"
>
    <Reveal class="gap-content-gap flex w-full flex-col">
        <Text variant="title" as="h1" class="break-all md:break-normal">
            {post.title}
        </Text>
        <Text variant="overline" class="text-subtle">{date}</Text>
        {
            post.tags && post.tags.length > 0 && (
                <div class="gap-tight-gap flex flex-wrap">
                    {post.tags.map((tag) => (
                        <span class="bg-surface text-muted rounded-full px-3 py-1 text-sm">
                            {tag}
                        </span>
                    ))}
                </div>
            )
        }
    </Reveal>
    {
        post.coverImage && (
            <Reveal>
                <Image
                    src={urlFor(post.coverImage).width(1200).height(600).url()}
                    widths={[600, 1200]}
                    sizes="(max-width: 768px) 100vw, 80vw"
                    alt={post.title}
                    width={1200}
                    height={600}
                    class="w-full object-contain"
                    loading="eager"
                />
            </Reveal>
        )
    }
</Section>
