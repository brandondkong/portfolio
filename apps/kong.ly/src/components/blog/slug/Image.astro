---
import { Image } from 'astro:assets';
import { urlFor } from '../../../lib/sanity';

const { node } = Astro.props;
const { asset, alt, caption } = node;
---

{
    asset && (
        <figure>
            <Image
                src={urlFor({ asset }).width(1200).url()}
                widths={[600, 1200]}
                sizes="(max-width: 768px) 100vw, 80vw"
                alt={alt || 'Blog post image'}
                width={1200}
                height={675}
                loading="lazy"
                class="w-full"
            />
            {caption && (
                <figcaption class="text-subtle mt-2 mb-8 text-center text-sm">
                    {caption}
                </figcaption>
            )}
        </figure>
    )
}
