---
import Base from '../../layouts/Base.layout.astro';
import JsonLd from '../../components/common/JsonLd.astro';
import Hero from '../../components/blog/Hero.astro';
import { SITE } from '../../lib/constants';
---

<Base
    title="Blog"
    description="Thoughts on engineering, design, and building things."
>
    <JsonLd
        data={{
            '@context': 'https://schema.org',
            '@type': 'BreadcrumbList',
            itemListElement: [
                {
                    '@type': 'ListItem',
                    position: 1,
                    name: 'Home',
                    item: SITE.url,
                },
                {
                    '@type': 'ListItem',
                    position: 2,
                    name: 'Blog',
                    item: `${SITE.url}/blog`,
                },
            ],
        }}
    />
    <Hero />
</Base>
